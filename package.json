{
  "name": "wallet-service",
  "version": "1.0.0",
  "description": "Production-grade Internal Wallet Service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node prisma/seed.ts",
    "prisma:generate": "set PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 && prisma generate",
    "prisma:migrate": "set PRISMA_ENGINES_CHECKSUM_IGNORE_MISSING=1 && prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.10.2",
    "express": "^4.18.3",
    "pino": "^8.21.0",
    "pino-pretty": "^11.0.0",
    "prisma": "5.10.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/uuid": "^9.0.8",
    "dotenv": "^17.3.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
